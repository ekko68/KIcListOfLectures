		private void findPeople() { //사용자로부터 값을 입력 -> JOptionPane.showInputDialog
			try {
				rs = stmt.executeQuery(sql);   //where no = txtPbun;
				rs.beforeFirst(); // 맨 처음 보다 -1에 커서 위치.
				
				int couFind = 0;
				while(rs.next()) {//검색할 데이터가 있는 동안
					
						txtPbun.setText(rs.getString("no")); //고객번호
						txtPname.setText(rs.getString("name")); // 고객이름
						//txtCbun.setText(rs.getString("name")); //고양이 번호
						txtPtel.setText(rs.getString("tel")); //전화번호
						txtPjuso.setText(rs.getString("addr")); //주소
						txtsuspend.setText(rs.getString("suspend")); //고양이 분양여부
						note.setText("메 모"+rs.getString("note"));						
						
						//설문조사 번호
						txtRe_no.setText(rs.getString("no"));

						couFind++;
					break;
				}
				if(couFind==0) { //찾은 레코드가 없다면
					JOptionPane.showMessageDialog(this, "찾으시는 고객은 등록되지 않은 회원입니다. ");
				}//while
			}catch(Exception e) {System.out.println("findPeople() 메소드 호출시 문제 발생 : "+e);}			
		}
		
