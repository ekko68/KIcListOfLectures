	//추가 
	private void accDb() {
		try {
			// 1. 접속할 드라이버 종류를 정하기 (메모리에 올림)
			Class.forName("oracle.jdbc.driver.OracleDriver"); // ("oracle jdbc의 package 이름 . 드라이버")
			// 2. 접속하기위한 메소드 실제 DB의 (1.접속 url, 2. 계정명, 3.password)
			conn = DriverManager.getConnection("jdbc:oracle:thin:@localhost:1521:orcl", "scott", "tiger");
			// 추가 -> 확인이 아니라, (신규, 수정),(레코드 이동)을 누르더라도, 자동으로 스크롤 이동시 수정이 반영될 수 있도록
			stmt = conn.createStatement(ResultSet.TYPE_SCROLL_SENSITIVE, ResultSet.CONCUR_UPDATABLE);
			/*
			 * web에서는 사용 안함 ResultSet.TYPE_SCROLL_SENSITIVE -> 양방향으로 스크롤 이동시 업데이트 반영
			 * ResultSet.CONCUR_UPDATABLE -> 커서 위치에서 정보 업데이트 가능
			 */
			System.out.println("접속 con : " + conn);
		} catch (Exception e) {
			System.out.println("DB연결 테스트 실패 : " + e);
		}
	} //DB접속
	private void init() {
		try {
			sql = "select * from People order by no asc";
			rs = stmt.executeQuery(sql);
			//총 레코드 개수 출력 -> if 맨 마지막 레코드 번호로 이동 -> 총 레코드수와 같다.
			rs.last();
			iTotal= rs.getRow(); //현재의 행 번호 출력
			/*
			 * 총 레코드수 -> select count(*) from customer;
			 * 마지막 레코드 번호 -> select max(c_bun) from customer;
			 */
			iLast = rs.getInt("no"); //마지막 고객번호 -> 신규 고객에게 번호 부여 -> 마지막 고객번호 +1
			rs.first(); //첫 번째 레코드로 이동
			iFirst = rs.getRow();
		}catch(Exception e) {System.out.println("People테이블 불러오기 실패"+e);}
	} // 고객 테이블 Load
	
