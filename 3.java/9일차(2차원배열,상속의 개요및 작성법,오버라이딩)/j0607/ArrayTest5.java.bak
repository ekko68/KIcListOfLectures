package j0607;

import java.util.Arrays;//Scanner

public class ArrayTest5 {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
        System.out.println("배열의 정렬");
        boolean su[]=new boolean[3];//su[0],su[1],su[2]
        System.out.println("su[1]=>"+su[1]);//false
        String str[]= {"Banana","Orange","Apple"};
        System.out.println("배열의 정렬전 출력");
        ArrayTest5.arrayPrint(str);
        //확장for문->형식)for(배열의 자료형 출력변수명:배열명)
        /*for(String su2:str)																		
        	System.out.print("su2=>"+su2+"\t");*/
        System.out.println();//줄바꿈
        System.out.println("배열의 정렬후 출력");
        //배열의 값을 정렬시켜주는 메서드->Arrays.sort(정렬하고자하는 배열명)
        Arrays.sort(str);
        ArrayTest5.arrayPrint(str);
	}
    //출력할 배열의 값을 입력을 받아서 대신 출력시켜주는 부하직원
	static void arrayPrint(String  str[]) {//(String str[]) { //단순,반복
		for(String su2:str)	 //for(int i=0;i<str.length;i++){																
        	System.out.print("su2=>"+su2+"\t");
	}
	
}





