	public  Vector<ZipcodeDTO>   zipcodeRead(String area3) {
		
		Connection  con=null;
		PreparedStatement pstmt=null;
		ResultSet rs=null;//select
		//ïżœß°ïżœ
		Vector<ZipcodeDTO> vecList=new Vector();
		String sql="";//ïżœïżœïżœïżœïżœĆł sqlïżœïżœïżœïżœ
		//2.ïżœïżœïżœïżœïżœĆł SQLïżœïżœïżœïżœïżœïżœ ïżœÊżïżœ
		try {
			con=pool.getConnection();
			sql="select * from zipcode where area3 like '"+area3+"%'";
			pstmt=con.prepareStatement(sql);
			rs=pstmt.executeQuery();
			//ïżœïżœïżœÚ”ć°Ą ïżœŃ°ïżœ ïżœÌ»ïżœ
			while(rs.next()) {
				//vector or ZipcodeDTO(ïżœÊ”ćș°ïżœïżœ ïżœïżœïżœïżœ(Setter)->rs.getXXX(ïżœÊ”ïżœïżœ)
				ZipcodeDTO tempZipcode=new ZipcodeDTO();
				tempZipcode.setZipcode(rs.getString("zipcode"));//("142-890");
				tempZipcode.setArea1(rs.getString("area1"));
				tempZipcode.setArea2(rs.getString("area2"));
				tempZipcode.setArea3(rs.getString("area3"));
				tempZipcode.setArea4(rs.getString("area4"));
				//vector or ArrayListïżœïżœ ïżœïżœïżœ ïżœïżœïżœïżœ
				vecList.add(tempZipcode);//ïżœë·« 13ïżœïżœïżœïżœ ïżœïżœïżœÚ”ć°Ą ïżœïżœïżœïżœïżœïżœ ïżœÈŽïżœ.
			}
		}catch(Exception e) {
			System.out.println("zipcodeRead() ïżœïżœïżœïżœ ïżœïżœïżœïżœïżœïżœïżœïżœ->"+e);
		}finally {//3.DBïżœïżœïżœïżœïżœïżœïżœïżœ
			pool.freeConnection(con, pstmt, rs);
		}
		return vecList;
	}
	
