	public boolean memberUpdate(MemberDTO mem) {
		
		System.out.println("mem.getMem_id()=>"+mem.getMem_id());
		Connection  con=null;
		PreparedStatement pstmt=null;
		boolean check=false;//Èžïżœïżœïżœïżœïżœïżœ ïżœïżœïżœïżœïżœïżœïżœïżœ
		String sql="";//ïżœïżœïżœïżœïżœĆł sqlïżœïżœïżœïżœ
