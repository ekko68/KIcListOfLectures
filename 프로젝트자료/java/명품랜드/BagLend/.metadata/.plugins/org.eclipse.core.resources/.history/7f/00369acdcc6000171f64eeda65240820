	@Override
	public void actionPerformed(ActionEvent e) {
		// TODO Auto-generated method stub
		if(e.getSource() == btn_srch)  // 검색버튼 클릭시 이쪽으로 진입
			searchData(); 		
		else if(e.getSource() == confirm ) { //확인 클릭시
			
		
		}

	}
	
	public void searchData() {
		String txt = txtB_Num.getText().trim().replaceAll(" ", ""); //입력했을때 공백문자있으면 모두 제거        
		
		//아무것도 입력안했을때
		if(txt.equals("")) {
			JOptionPane.showMessageDialog(null,"값을 입력해야합니다");
		}
		
		//어떠한 값을 입력했을때
		else {
			ArrayList<String> product_name = new ArrayList<String>();
			
			for(Product pr : products) 
				if(pr.getTitle().contains(txt)) 
					product_name.add(pr.getTitle());
		
			titles = new String[product_name.size()];


			for(int i=0;i<titles.length;i++) {	
				titles[i]=product_name.get(i);
		//		System.out.println(titles[i]);
			}
			list.setListData(titles);
		}

	}
	public void getSelectedList() {
		for(int i = 0 ; i < titles.length ; i++) {
			if(list.getSelectedIndex() == i) {
				str = titles[i];
			}
		}		
	}

	@Override
	public void valueChanged(ListSelectionEvent e) {
