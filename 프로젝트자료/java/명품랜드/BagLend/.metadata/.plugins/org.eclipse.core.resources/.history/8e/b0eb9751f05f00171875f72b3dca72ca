	public ArrayList<Customer> selectAllData(Connection conn) {
		ArrayList<Customer> customer = new ArrayList<Customer>();

		String sql = "select * from custom";
		Statement stmt=null;
		ResultSet rs = null;
		
		try {
			System.out.println("Debug2");
			
			stmt = conn.createStatement();
			System.out.println("Debug");
			rs=stmt.executeQuery(sql);

			while(rs.next()) {
				 customer.add(new Customer(rs.getInt("product_num"), rs.getString("name")
						,rs.getString("tel"), rs.getString("gender") ,rs.getInt("age"),
						rs.getString("address"),rs.getString("coupon_num"),rs.getString("start_date"),rs.getString("end_date")));	
			}	
			
		} catch (SQLException e) {
			e.printStackTrace();
		}finally {
			CloseJdbc.close(rs);
			CloseJdbc.close(stmt);
			
		}
		return customer;
	}
