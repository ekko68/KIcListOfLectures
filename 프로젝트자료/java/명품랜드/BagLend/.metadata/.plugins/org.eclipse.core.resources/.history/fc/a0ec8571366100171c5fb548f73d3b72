	// 이벤트 처리 메소드
	private void addListener() {	
		confirmbtn.addActionListener(this); // 확인
		cancelbtn.addActionListener(this); // 취소
		imgEdit.addActionListener(this); // 이미지 등록 버튼

	}
	
	@Override
	public void actionPerformed(ActionEvent e) {
		// TODO Auto-generated method stub
		if (e.getSource() == imgEdit) {
			file = null; // 불러올 이미지의 파일 정보를 담을 객체
			JFileChooser fileChooser = new JFileChooser();
			// fileChooser.setFileFilter(new FileNameExtensionFilter("jpg", "png", "gif"));
			// // 파일 필터
			fileChooser.setMultiSelectionEnabled(false);// 다중 선택 불가
			fileChooser.setFileSelectionMode(JFileChooser.FILES_ONLY);
			int result = fileChooser.showOpenDialog(fUpdate);

			if (result == JFileChooser.CANCEL_OPTION) {
				file = null;
			} else {
				file = fileChooser.getSelectedFile(); // 선택한 이미지 파일명
				imgPath = file.getPath().replace("\\", "/"); // getPath(); 현재 불러올 경로,
				System.out.println("선택한 이미지 파일 경로 확인(imgPath) : " + imgPath);
				displayImage(); // 이미지+JLabel 화면에 출력
			} 
		} // imgAdd
		
		else if(e.getSource() == cancelbtn) {
			fUpdate.setVisible(false);
			//C_Insert.setEnabled(true);
		} // cancelbtn
		
		
		else if(e.getSource() == confirmbtn) {

			//productDB.insertProduct(MakeConnection.getInstance(), product);
			fUpdate.dispose();
		}

	}

