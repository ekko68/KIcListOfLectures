	public void outPutProduct() {
		ImageIcon pdImg=new ImageIcon(product.get(start).getImage());
		Image pd_Img = pdImg.getImage();
		Image imgResize = pd_Img.getScaledInstance(565, 520, Image.SCALE_DEFAULT);
		ImageIcon imgIcon = new ImageIcon(imgResize);

		txtB_Num.setText(product.get(start).getNum() + "");
		txtB_Check.setText(product.get(start).getTitle());
		txtB_Title.setText(product.get(start).getState());
		txtB_Title.setForeground(new Color(255, 0, 0));
		txtB_Infor.setText(product.get(start).getInfo());
		Product_image.setIcon(imgIcon);
		
	}
	

	@Override
	public void actionPerformed(ActionEvent e) {
		// TODO Auto-generated method stub
		if(e.getSource() == C_Select) {   //°Ë»ö ´­·¶Ŕ»¶§
			SearchPage search = new SearchPage(this);
		}
		
		else if(e.getSource() == C_Back) { // ŔĚŔüąöĆ° ´­·¶Ŕ»¶§
			if(start-1<0) {
				JOptionPane.showMessageDialog(frame, "Ăą ĆäŔĚÁöŔÔ´Ď´Ů");
				return ;
			}
			else
				start--;	
		}
		
		else if(e.getSource() == C_Next) { // ´ŮŔ˝ąöĆ° ´­·¶Ŕ»¶§
			if(start>=product.size()-1) {
				JOptionPane.showMessageDialog(frame, "¸¶Áö¸· ĆäŔĚÁöŔÔ´Ď´Ů");
				return ;	
			}
			else
				start++;		
		}
		
	//	else if(e.getSource() == C_Insert) { // insertąöĆ° ´­·¶Ŕ»¶§
	//		new InsertProductPage();
			
	//	}
		
		else if(e.getSource() == C_delete) {
			HandleProductDB db = new HandleProductDB();
			db.deleteProduct(MakeConnection.getInstance(), txtB_Num.getText());
			
		}	
		
		product = makeProduct();
		pdRec.setText((start+1)+"/"+(end=product.size()));
		outPutProduct();
		
	}

	
