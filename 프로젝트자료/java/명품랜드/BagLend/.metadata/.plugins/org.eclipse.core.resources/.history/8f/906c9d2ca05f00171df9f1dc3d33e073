package bag.event.handler;

import java.awt.event.ActionEvent;
import java.awt.event.ActionListener;

import bag.design.page.CustomerPage;
import bag.design.page.MainPage;
import bag.design.page.ProductPage;

public class Handler implements ActionListener {
	
	private MainPage mainPage;
	
	public Handler(){
		mainPage=new MainPage();
	}

	@Override
	public void actionPerformed(ActionEvent e) {
		// TODO Auto-generated method stub
		
		if(e.getSource().equals(btnCustomer)) {
			CustomerPage cp = new CustomerPage();
				childWinCustomer.getContentPane().add(cp);
				childWinCustomer.setLocation(10, 10);
				frame.getContentPane().add(childWinCustomer, JLayeredPane.PALETTE_LAYER);
				childWinCustomer.show();
				btnCustomer.setEnabled(false);
				
			} else if(e.getSource().equals(btnBag)) {
				ProductPage pg = new ProductPage();
				childWinCustomer.getContentPane().add(pg);
				childWinCustomer.setLocation(10, 10);
				frame.getContentPane().add(childWinBag, JLayeredPane.PALETTE_LAYER);
				childWinBag.show();
				btnBag.setEnabled(false);
			}
	}

}
