	@Override
	public void actionPerformed(ActionEvent e) {
		// TODO Auto-generated method stub
		
		if(e.getSource()==C_Select) { // °Ë»ö(select)ąöĆ° Ĺ¬¸ŻÇŃ °ćżě
			search = new Search(this);
			System.out.println("ŔĚ°Ĺ?"+getItem);
			
		}
		else if(e.getSource()== C_delete) {
			start--;
		}
		
		else if(e.getSource() == C_Insert) {  //˝Ĺ±Ôµî·Ď ´­·¶Ŕ»¶§
			new InsertProduct();
			System.out.println("check");
		}
		
		else if(e.getSource() == C_Back) {
			if(start<0) {
				JOptionPane.showMessageDialog(frame, "Ăą ĆäŔĚÁöŔÔ´Ď´Ů");
				return ;
			}
			else
				start--;	
		}
		
		else if(e.getSource() == C_Next) {
	
			if(start>=end) {
				JOptionPane.showMessageDialog(frame, "¸¶Áö¸· ĆäŔĚÁöŔÔ´Ď´Ů");
				return ;	
			}
			else
				start++;	
			
		}
		
		else if(e.getSource() == closebtn) {
			System.out.println(getItem);
			for(int i=0;i<product.size();i++) {
				if(getItem == product.get(i).getTitle()) {
					System.out.println(product.get(i).getTitle());
					start=i;
					fSearch.setVisible(false);
				}
			}
		}
		System.out.println(" ąąľß??");
	//	if(start<=19 && start>=0)
		pdRec.setText((start+1)+"/"+end);
		firstOutPut();
	}


