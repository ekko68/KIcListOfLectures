	public void displayImage() {
		ImageIcon icon = createImageIcon(imgPath);
		// 이미지 리사이징
		Image pd_Img = icon.getImage();
		Image imgResize = pd_Img.getScaledInstance(565, 520, Image.SCALE_DEFAULT);
		ImageIcon imgIcon = new ImageIcon(imgResize);
		Product_Image.setIcon(imgIcon);

		// 이미지를 불러오지 못한 경우
		if (icon != null) {
			Product_Image.setText(null);
		} else {
			Product_Image.setText("이미지가 없습니다.");
		}
	}

	// 경로를 지정하면 이미지를 만들어서 불러오는 메소드
	private ImageIcon createImageIcon(String path) {
		if (path != null) { // 불러올 이미지의 경로가 있다면 이미지 객체 생성
			// swing에서 이미지를 생성하면 이미지를 만들어주는 ImageIcon이 있다
			// ImageIcon 객채명 = new ImageIcon(경로포함 파일명)
			return new ImageIcon(path);

		} else {
			System.out.println("이미지를 불러오기 실패(경로 불분명)");
			return null; // 이미지 객체 정보를 만들 수 없다
		}
	}
	
