package bag.lend.controller;

import java.awt.event.ActionEvent;
import java.awt.event.ActionListener;

import javax.swing.JLayeredPane;

import bag.design.page.CustomerPage;
import bag.design.page.MainPage;


public class Controller implements ActionListener{
	
	private MainPage mainPage;
	
	public Controller() {
		mainPage = new MainPage();
	}

	@Override
	public void actionPerformed(ActionEvent e) {
		// TODO Auto-generated method stub
		if(e.getSource().equals(mainPage.getBtnCustomer())) {
			CustomerPage cp = new CustomerPage();
			childWinCostomer.getContentPane().add(cp);
			childWinCostomer.setLocation(10, 10);
			frame.getContentPane().add(childWinCostomer, JLayeredPane.PALETTE_LAYER);
			childWinCostomer.show();
			btnCustomer.setEnabled(false);
			
		}
		
	}
}
