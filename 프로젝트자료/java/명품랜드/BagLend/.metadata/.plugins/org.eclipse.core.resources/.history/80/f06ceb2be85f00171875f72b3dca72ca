package bag.lend.dbdata;

public class Coupon {

	private String num;
	private String info;
	public Coupon(String num,String info)
	{
		this.num=num;
		this.info=info;
	}
	public String getNum() {
		return num;
	}
	public void setNum(String num) {
		this.num = num;
	}
	public String getInfo() {
		return info;
	}
	public void setInfo(String info) {
		this.info = info;
	}
	
}
