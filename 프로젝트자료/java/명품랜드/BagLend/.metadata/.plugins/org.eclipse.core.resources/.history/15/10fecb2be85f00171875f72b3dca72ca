package bag.lend.handlesql;

import java.sql.*;
import java.util.ArrayList;

import bag.lend.dbdata.Coupon;
import bag.lend.jdbcutil.JdbcUtill;

public class HandleCouponDB {

	private String sql;
	private Statement stmt;
	private ResultSet rs;
	
	public ArrayList<Coupon> selectAllData(Connection conn){
		ArrayList<Coupon> coupon=new ArrayList<Coupon>();
		sql="select*from coupon";
		stmt=null;
		rs=null;
		try {
			stmt=conn.createStatement();
			rs=stmt.executeQuery(sql);
			
			coupon.add(new Coupon(rs.getString("coupon_num"),
					rs.getString("coupon_info")));
		}catch(Exception e) {
			e.printStackTrace();
		}finally {
			JdbcUtill.close(rs);
			JdbcUtill.close(stmt);
		}
		
		
		return coupon;
		
	}
}
