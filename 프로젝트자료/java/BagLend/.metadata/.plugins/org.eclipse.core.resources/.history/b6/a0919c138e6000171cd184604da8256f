	@Override
	public void actionPerformed(ActionEvent e) {
		// TODO Auto-generated method stub
		// 신규
		
		if(e.getSource()==C_Insert) { // 신규(insert)버튼 클릭한 경우	
			fInsert.setVisible(true);
		}
		
		else if(e.getSource()==C_Select) { // 검색(select)버튼 클릭한 경우	
			fSearch.setVisible(true);
			
		}
		else if(e.getSource() == btnNewButton) {
			System.out.println("check");
			searchData();
		}
		
		else if(e.getSource() == C_Back) {
			if(start<0)
				JOptionPane.showMessageDialog(frame, "첫 페이지입니다");
			else
				start--;	
		}
		
		else if(e.getSource() == C_Next) {
			System.out.println(end);
			if(start>end) 
				JOptionPane.showMessageDialog(frame, "마지막 페이지입니다");
			else
				start++;			
		}
		
		else if(e.getSource() == closebtn) {
			System.out.println(getItem);
			for(int i=0;i<product.size();i++) {
				if(getItem == product.get(i).getTitle()) {
					System.out.println(product.get(i).getTitle());
					start=i;
					fSearch.setVisible(false);
				}
			}
		}
		pdRec.setText((start+1)+"/"+end);
		outPutProduct();
	}
	
	public void searchData() {
