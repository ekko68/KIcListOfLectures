	// 이벤트 처리 메소드 
	private void addListener() {
		C_Insert.addActionListener(this); // 신규
		C_Update.addActionListener(this); // 수정
		C_delete.addActionListener(this); // 삭제
		C_Select.addActionListener(this); // 검색
		
		btnClose.addActionListener(this); // 닫기
		C_Back.addActionListener(this); // 이전
		C_Next.addActionListener(this); // 다음
	}
	
