package bag.handle.sql;

import java.sql.*;
import bag.db.data.Coupon;

public class HandleCouponDB {

	private String sql;
	private Statement stmt;
	private ResultSet rs;
	
	public String selectAllData(Connection conn){
	
		sql="select*from coupon";
		stmt=null;
		rs=null;
		try {
			stmt=conn.createStatement();
			rs=stmt.executeQuery(sql);
			
	
		}catch(Exception e) {
			e.printStackTrace();
		}
		
		
		return null;
		
	}
}
