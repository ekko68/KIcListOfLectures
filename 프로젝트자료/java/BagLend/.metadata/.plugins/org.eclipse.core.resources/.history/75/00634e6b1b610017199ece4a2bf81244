package bag.handle.sql;

import java.sql.Connection;
import java.sql.PreparedStatement;
import java.sql.ResultSet;
import java.sql.SQLException;
import java.sql.Statement;
import java.util.ArrayList;

import bag.db.data.Customer;
import bag.memory.close.CloseJdbc;

public class HandleCustomDB {
	
	public Customer selectCustomer(Connection conn,String name) {
		String sql = "select * from custom where=?";
		PreparedStatement pstm =null;
		ResultSet rs =null;
		Customer customer = null;
		
		try {
			pstm = conn.prepareStatement(sql);
			rs = pstm.executeQuery();
			
			
			while(rs.next())
				customer = getDataFromResultSet(rs); //getDataFromResultSet은 rs에서 데이터가져와 출력해주는 함수
		} catch (Exception e) {
			// TODO: handle exception
		}
		
		return customer;
	}
	
	public ArrayList<Customer> selectAllData(Connection conn) {
		ArrayList<Customer> customer = new ArrayList<Customer>();

		String sql = "select * from custom";
		Statement stmt=null;
		ResultSet rs = null;
		
		try {		
			stmt = conn.createStatement();
			rs=stmt.executeQuery(sql);

			while(rs.next()) 
				 customer.add(getDataFromResultSet(rs));
			
		} catch (SQLException e) {
			e.printStackTrace();
		}finally {
			CloseJdbc.close(rs);
			CloseJdbc.close(stmt);
			
		}
		return customer;
	}
	//insert into custom(product_num,name,tel,gender,age,address,coupon_num,start_date,end_date)
	//values(42281567,'박성진','010-8585-9696','M',27,'서울특별시 강남구 서초동','C823781','2017-06-20','2017-07-20');

	public void insertData(Connection conn,String custom[]) {
		String sql = "insert into custom values(?,?,?,?,?,?,?,?,?)";
		
		PreparedStatement pstm=null;

		try {
			pstm = conn.prepareStatement(sql);
		
			pstm.setInt(1, 5);
			pstm.setString(2, "전지현");
			pstm.setString(3,"010-2454-2674" );
			pstm.setString(4, "여");
			pstm.setInt(5, 32);
			pstm.setString(6, "서울시 관악구 9동");
			pstm.setString(7, "3개월 사용권");
		
			pstm.executeUpdate();
			
		} catch (SQLException e) {
			e.printStackTrace();
		} finally {
			CloseJdbc.close(pstm);
		}
	}
	
	public Customer getDataFromResultSet(ResultSet rs) throws SQLException {
		Customer customer = new Customer(rs.getInt("product_num"), rs.getString("name"),
							rs.getString("tel"), rs.getString("gender") ,rs.getInt("age"),
							rs.getString("address"),rs.getString("coupon_num"),rs.getString("start_date"),rs.getString("end_date"));
		return customer;
		
	}
	

}
