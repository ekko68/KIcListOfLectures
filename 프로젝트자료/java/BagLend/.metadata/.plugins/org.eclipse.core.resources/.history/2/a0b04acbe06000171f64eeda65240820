	@Override
	public void actionPerformed(ActionEvent e) {
		// TODO Auto-generated method stub
		
		if(e.getSource()==C_Select) { // 匐儀(select)幗⑹ 贗葛フ 唳辦
			search = new Search(this);	
		}
		else if(e.getSource()== C_delete) {
			start--;
		}
		
		else if(e.getSource() == C_Insert) {  //褐敘蛔煙 揚毓擊陽
			new InsertProductPage();
			System.out.println("check");
		}
		
		else if(e.getSource() == C_Back) {
			if(start-1<0) {
				JOptionPane.showMessageDialog(frame, "羅 ［檜雖殮棲棻");
				return ;
			}
			else
				start--;	
		}
		
		else if(e.getSource() == C_Next) {
	
			if(start>=end-1) {
				JOptionPane.showMessageDialog(frame, "葆雖虞 ［檜雖殮棲棻");
				return ;	
			}
			else
				start++;		
		}

		
	//	if(start<=19 && start>=0)
		pdRec.setText((start+1)+"/"+end);
		firstOutPut();
	}

