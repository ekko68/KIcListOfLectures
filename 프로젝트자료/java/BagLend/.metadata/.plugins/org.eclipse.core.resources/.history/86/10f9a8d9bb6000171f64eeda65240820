	public ArrayList<CustomPageInfo> getCustomPageInfo(){ //dbż¬µż
		Connection conn = MakeConnection.getInstance();
		
		HandleCustomDB customerDB = new HandleCustomDB();
		HandleCouponDB couponDB = new HandleCouponDB();
		HandleProductDB productDB = new HandleProductDB();
		
		ArrayList<CustomPageInfo> cpi = new ArrayList<CustomPageInfo>();
		
		ArrayList<Customer> customer = customerDB.selectAllData(conn);

		for(Customer arr : customer) {
			Coupon coupon= couponDB.selectedCoupon(conn, arr.getName());
			System.out.println(arr.getName());
			Product product = productDB.selectedProduct(conn, arr.getName());
			
			cpi.add(new CustomPageInfo(arr.getProduct_num(),
									   arr.getName(),
									   arr.getTel(),
									   arr.getGender(),
									   arr.getAge(),
									   arr.getAddress(),
									   coupon.getInfo(),
									   product.getTitle(),
									   product.getImage()));
		}
		
		return cpi;
		

	}
	
	public void display() {
		ArrayList<CustomPageInfo> cpi = getCustomPageInfo();
		String[] name = new String[cpi.size()]; 
		
		for(int i=0;i<cpi.size();i++) {
			name[i]=cpi.get(i).getName();
		}
		list.setListData(name);
	}

