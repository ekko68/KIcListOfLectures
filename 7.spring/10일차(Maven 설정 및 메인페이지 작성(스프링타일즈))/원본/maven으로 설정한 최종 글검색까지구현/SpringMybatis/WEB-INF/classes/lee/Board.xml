<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="board">
 
<!--테이블에 대한 insert,update,delete,select에 대한 설정  -->
<!--1.게시판의 글목록보기(select)  -->

<select id="list" resultType="board">
   select * from springboard order by num desc
</select>

<!-- 2.최대글번호 구하기 -->
<select id="getNewNum" resultType="int">
    select max(num) from springboard
</select>

<!-- 3.글쓰기 #{매개변수명(=멤버변수명)} 
  오라클->오늘날짜(sysdate)->mysql(now())
  insert,update,delete->resultType속성이 X
-->

<insert id="write" parameterType="board">
  insert into springboard(num,author,title,content,writeday)
  values(#{num},#{author},#{title},#{content},sysdate)
</insert>

<!-- 4.조회수 증가하기(수정) -->
<update id="updatecnt" parameterType="String">
   update springboard set readcnt=readcnt+1
   where num=#{num}
</update>

<!-- 5. 글상세보기-->
<select id="retrieve" resultType="board" 
           parameterType="String">
   select * from springboard where num=#{num}
</select>

<!-- 6.글수정하기 -->
<update id="update" parameterType="board">
   update springboard set title=#{title},
                                    content=#{content},
                                    author=#{author}
                                    where num=#{num}
</update>

<!-- 7.글삭제하기(id="delete") -->

<delete id="delete" parameterType="String">
   delete from springboard where num=#{num}
</delete>

<!-- 8.글조회하기 -->
<select id="search" parameterType="board"
           resultType="board">
   select * from springboard where ${searchName} 
   like '%${searchValue}%' order by num desc
</select>

</mapper>





